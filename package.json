{
  "name": "cleartalk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A tool that helps you talk to people better",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/generate-insight-pages.mjs",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run test && npm run build",
    "e2e": "npm run build && npx playwright test",
    "e2e:headed": "npm run build && npx playwright test --headed",
    "review": "npm run check && npm run audit:deps && npm run size",
    "audit:deps": "npm audit --omit=dev || true",
    "size": "du -sh dist/ && echo '---' && ls -lhS dist/assets/",
    "generate:assets": "node scripts/generate-assets.mjs"
  },
  "dependencies": {
    "dexie": "^4.3.0",
    "preact": "^10.29.0",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.10.4",
    "@types/node": "^24.12.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  }
}
